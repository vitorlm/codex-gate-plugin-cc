          "severity",
          "file",
          "line_start",
          "line_end",
          "title",
          "detail",
          "suggestion"
        ],
        "properties": {
          "category": { "type": "string" },
          "severity": { "enum": ["blocker", "major", "minor", "info"] },
          "file": { "type": "string" },
          "line_start": { "type": ["integer", "null"] },
          "line_end": { "type": ["integer", "null"] },
          "title": { "type": "string" },
          "detail": { "type": "string" },
          "suggestion": { "type": ["string", "null"] }
        }
      }
    },
    "next_steps": { "type": "array", "items": { "type": "string" } }
